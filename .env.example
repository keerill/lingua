# ---------------------------------------------------------------------------
# Lingua — Slice 1 environment. Copy to `.env` for local dev.
# Infra is provided by infra/docker/docker-compose.dev.yml.
# ---------------------------------------------------------------------------

# Databases (db-per-service; one Postgres container, separate logical DBs)
DATABASE_URL_IDENTITY=postgresql://lingua:lingua@localhost:5432/identity?schema=public
DATABASE_URL_VOCABULARY=postgresql://lingua:lingua@localhost:5432/vocabulary?schema=public
DATABASE_URL_LEARNING=postgresql://lingua:lingua@localhost:5432/learning?schema=public

# Kafka (KRaft, single broker)
KAFKA_BROKERS=localhost:9092

# Redis
REDIS_URL=redis://localhost:6379

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=lingua
KEYCLOAK_BFF_CLIENT_ID=lingua-bff
KEYCLOAK_BFF_CLIENT_SECRET=lingua-bff-secret
KEYCLOAK_SHELL_CLIENT_ID=lingua-shell

# Service ports
SVC_IDENTITY_PORT=3101
SVC_VOCABULARY_PORT=3102
SVC_LEARNING_PORT=3103
GATEWAY_BFF_PORT=3000

# Internal service URLs (BFF → services)
SVC_IDENTITY_URL=http://localhost:3101
SVC_VOCABULARY_URL=http://localhost:3102
SVC_LEARNING_URL=http://localhost:3103

# BFF session/cookie
BFF_COOKIE_SECRET=dev-cookie-secret-change-me
BFF_PUBLIC_URL=http://localhost:3000
SHELL_PUBLIC_URL=http://localhost:4200
