# ---------------------------------------------------------------------------
# Lingua — environment. Copy to `.env` for local dev.
# Infra is provided by infra/docker/docker-compose.dev.yml.
# ---------------------------------------------------------------------------

# Databases (db-per-service; one Postgres container, separate logical DBs)
DATABASE_URL_IDENTITY=postgresql://lingua:lingua@localhost:5432/identity?schema=public
DATABASE_URL_VOCABULARY=postgresql://lingua:lingua@localhost:5432/vocabulary?schema=public
DATABASE_URL_LEARNING=postgresql://lingua:lingua@localhost:5432/learning?schema=public
# svc-ai-dialog (dialog sessions/turns + outbox).
DATABASE_URL_DIALOG=postgresql://lingua:lingua@localhost:5432/dialog?schema=public
# content / progress (read-model) / notifications.
DATABASE_URL_CONTENT=postgresql://lingua:lingua@localhost:5432/content?schema=public
DATABASE_URL_PROGRESS=postgresql://lingua:lingua@localhost:5432/progress?schema=public
DATABASE_URL_NOTIFICATIONS=postgresql://lingua:lingua@localhost:5432/notifications?schema=public

# Kafka (KRaft, single broker).
KAFKA_BROKERS=localhost:9092

# Redis
REDIS_URL=redis://localhost:6379

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=lingua
KEYCLOAK_BFF_CLIENT_ID=lingua-bff
KEYCLOAK_BFF_CLIENT_SECRET=lingua-bff-secret

# Service ports
SVC_IDENTITY_PORT=3101
SVC_VOCABULARY_PORT=3102
SVC_LEARNING_PORT=3103
SVC_AI_DIALOG_PORT=3104
SVC_SPEECH_PORT=3105
# services
SVC_CONTENT_PORT=3106
SVC_PROGRESS_PORT=3107
SVC_NOTIFICATIONS_PORT=3108
GATEWAY_BFF_PORT=3000

# Internal service URLs (BFF → services)
SVC_IDENTITY_URL=http://localhost:3101
SVC_VOCABULARY_URL=http://localhost:3102
SVC_LEARNING_URL=http://localhost:3103
SVC_AI_DIALOG_URL=http://localhost:3104
SVC_SPEECH_URL=http://localhost:3105
#
SVC_CONTENT_URL=http://localhost:3106
SVC_PROGRESS_URL=http://localhost:3107
SVC_NOTIFICATIONS_URL=http://localhost:3108

# BFF session/cookie
BFF_COOKIE_SECRET=dev-cookie-secret-change-me
BFF_PUBLIC_URL=http://localhost:3000
SHELL_PUBLIC_URL=http://localhost:4200

# --- speaking micro-frontend (MF remote) --
MFE_SPEAKING_PORT=4202
MFE_SPEAKING_REMOTE=http://localhost:4202/mf-manifest.json

# --- progress + studio MF remotes; public Next.js site --
MFE_PROGRESS_PORT=4203
MFE_PROGRESS_REMOTE=http://localhost:4203/mf-manifest.json
MFE_STUDIO_PORT=4204
MFE_STUDIO_REMOTE=http://localhost:4204/mf-manifest.json
# Public SSR site (Next.js 16, App Router) — separate app, NOT Module Federation.
WEB_PUBLIC_PORT=4205
# svc-content base URL the public site fetches scenario previews from (server-side).
CONTENT_PUBLIC_API_URL=http://localhost:3106
# svc-notifications reminder schedule (node-cron / @nestjs/schedule expression).
NOTIFICATIONS_REMINDER_CRON=0 9 * * *

# --- MinIO (audio object store) --
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lingua-audio
# Browser-facing base URL used to build playable TTS links.
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_SECURE=false

# --- AI providers --
# Pluggable hexagonal ports. Default `fake` adapters are deterministic and need no
# keys or models — the whole flow + tests run offline. Switch to real engines here:
#   LLM_PROVIDER=anthropic   STT_PROVIDER=transformers   TTS_PROVIDER=piper
LLM_PROVIDER=fake
STT_PROVIDER=fake
TTS_PROVIDER=fake
# Anthropic (used only when LLM_PROVIDER=anthropic).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Transformers.js Whisper (used only when STT_PROVIDER=transformers).
# Opt-in dep: `pnpm add -w @huggingface/transformers`.
WHISPER_MODEL=Xenova/whisper-tiny.en
# Piper voice (used only when TTS_PROVIDER=piper; requires the `piper` CLI on PATH).
PIPER_VOICE=en_US-lessac-medium

# --- OpenTelemetry (traces + metrics + logs over OTLP) --
# OPT-IN: instrumentation starts only when OTEL_EXPORTER_OTLP_ENDPOINT is set,
# so leaving these commented keeps `nx serve` exactly as before. To run the dev
# observability demo, bring up the stack and UNCOMMENT the endpoint:
#   docker compose -f infra/docker/docker-compose.dev.yml \
#                  -f infra/docker/docker-compose.observability.yml up -d
# Service name is auto-derived from each app's package.json (e.g. svc-learning).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- internal gRPC + Kafka Schema Registry --
# Internal service-to-service calls run over gRPC (host:port). The servers bind
# these ports; the BFF (learning/vocabulary/identity/progress) and svc-ai-dialog
# (content) dial the matching *_GRPC_URL. Defaults already match the code, so
# these are here for visibility / overrides.
SVC_IDENTITY_GRPC_PORT=50051
SVC_VOCABULARY_GRPC_PORT=50052
SVC_LEARNING_GRPC_PORT=50053
SVC_CONTENT_GRPC_PORT=50056
SVC_PROGRESS_GRPC_PORT=50057
SVC_IDENTITY_GRPC_URL=localhost:50051
SVC_VOCABULARY_GRPC_URL=localhost:50052
SVC_LEARNING_GRPC_URL=localhost:50053
SVC_CONTENT_GRPC_URL=localhost:50056
SVC_PROGRESS_GRPC_URL=localhost:50057
# Kafka Schema Registry (Confluent, Protobuf). OPT-IN: when set, events are
# Protobuf-encoded through the registry; unset → JSON (so plain `nx serve` and
# all tests are unchanged). Bring up the registry and UNCOMMENT to run the demo:
#   docker compose -f infra/docker/docker-compose.dev.yml \
#                  -f infra/docker/docker-compose.schema-registry.yml up -d
# SCHEMA_REGISTRY_URL=http://localhost:8081
