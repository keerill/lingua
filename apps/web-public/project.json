{
  "name": "web-public",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web-public",
  "projectType": "application",
  "tags": ["scope:public", "type:web-ssr"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/web-public",
        "command": "next dev -p 4205"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "cwd": "apps/web-public",
        "command": "next build"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/web-public",
        "command": "next start -p 4205"
      }
    }
  }
}
