{
  "name": "svc-vocabulary",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/svc-vocabulary/src",
  "projectType": "application",
  "tags": ["scope:vocabulary", "type:service"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/svc-vocabulary",
        "command": "node --env-file=../../.env --watch -r @swc-node/register src/main.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/svc-vocabulary",
        "command": "tsc -p tsconfig.app.json"
      }
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/svc-vocabulary",
        "command": "prisma generate"
      }
    },
    "prisma-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/svc-vocabulary",
        "command": "prisma migrate dev"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/svc-vocabulary/jest.config.ts"
      }
    }
  }
}
