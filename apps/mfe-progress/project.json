{
  "name": "mfe-progress",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mfe-progress/src",
  "projectType": "application",
  "tags": ["scope:progress", "type:mfe-remote"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/mfe-progress",
        "command": "rspack build -c rspack.config.cjs"
      },
      "configurations": {
        "production": { "args": ["--mode", "production"] },
        "development": { "args": ["--mode", "development"] }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mfe-progress",
        "command": "rspack serve -c rspack.config.cjs"
      }
    }
  }
}
