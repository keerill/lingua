{
  "name": "gateway-bff",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/gateway-bff/src",
  "projectType": "application",
  "tags": ["scope:bff", "type:gateway"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/gateway-bff",
        "command": "node --env-file=../../.env --watch -r @swc-node/register src/main.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/gateway-bff",
        "command": "tsc -p tsconfig.app.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/gateway-bff/jest.config.ts"
      }
    }
  }
}
